# Copy to .env.local and fill in your values. Do not commit .env.local.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brevo (for app emails: application received, welcome, admin notifications)
BREVO_API_KEY=your-brevo-api-key
# Must match a verified sender in Brevo (e.g. info@pbkleadership.org.za)
BREVO_FROM_EMAIL=info@yourdomain.com
EMAIL_FROM_NAME=PBK Memorial Leadership Institute

# Optional: Resend as fallback if Brevo fails
RESEND_API_KEY=

# Support and admin notifications
SUPPORT_EMAIL=support@pbkleadership.org.za
ADMIN_NOTIFY_EMAIL=admin@example.com

# App URL (used in email links; use https for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
